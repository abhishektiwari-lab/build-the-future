# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Moderator Password (hash this in production)
NEXT_PUBLIC_MODERATOR_PASSWORD=change-me-in-production

# Session Secret
NEXT_PUBLIC_SESSION_SECRET=your-random-session-secret

# Judge Access Codes (comma-separated or configure via UI)
# JUDGE_ACCESS_CODES=JUDGE001,JUDGE002,JUDGE003
